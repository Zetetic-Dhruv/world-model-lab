{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Test Suite Dataset Pair",
  "description": "The experimental unit: train_env vs ood_test_env over a shared schema. Directional (train→test); a single dataset cannot exhibit OOD alone. Pairs are the entry points methods consume — single-dataset manifests are the building blocks.",
  "type": "object",
  "required": [
    "schema_version",
    "name",
    "members",
    "shift_axis",
    "pair_type",
    "train_env",
    "ood_test_env",
    "epistemic_state"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "examples": ["0.1.0"]
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "members": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1,
      "description": "Dataset names. 1 member = intra-dataset env split (e.g., year-split); 2+ = cross-dataset pair (e.g., CAMELS-US + CAMELS-DK)"
    },
    "shared_schema": {
      "type": "boolean",
      "description": "True iff members declare schema-compatible event_types / node_types"
    },
    "shift_axis": {
      "type": "string",
      "description": "The env axis the pair operates on (must match members' env_axis.name)"
    },
    "pair_type": {
      "type": "string",
      "enum": [
        "cross-population",
        "cross-time",
        "cross-instrument",
        "cross-composition",
        "cross-source",
        "cross-language",
        "cross-experimental-batch",
        "replication",
        "intra-dataset-env-split"
      ],
      "description": "The kind of shift the pair operates on; used to match methods to pairs. Replication has attempt-outcome label-noise atypical of other pair types."
    },
    "train_env": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "ood_test_env": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "epistemic_state": {
      "type": "object",
      "required": ["facts", "hypotheses", "intuitions", "unknowns"],
      "additionalProperties": false,
      "properties": {
        "facts": {"type": "array", "items": {"type": "string"}},
        "hypotheses": {"type": "array", "items": {"type": "string"}},
        "intuitions": {"type": "array", "items": {"type": "string"}},
        "unknowns": {"type": "array", "items": {"type": "string"}}
      },
      "description": "Pair-level epistemic notes; distinct from per-member notes"
    },
    "baselines": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "ref", "metric", "value"],
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string"},
          "ref": {"type": "string"},
          "metric": {"type": "string"},
          "value": {"type": "number"}
        }
      }
    }
  }
}
